window.onscroll = function() {
  scrollButton();
};

function scrollButton() {
  let button = document.getElementById("topButton");

  if (button) {
    if (document.documentElement.scrollTop > 300) {
      button.style.display = "block";
    } else {
      button.style.display = "none";
    }
  }
}

function goTop() {
  window.scrollTo({
    top: 0,
    behavior: "smooth"
  });
}
#topButton {
  display:none;
  position:fixed;
  bottom:20px;
  right:20px;
  padding:12px 18px;
  border:none;
  border-radius:50px;
  background:#38bdf8;
  color:#020617;
  font-weight:bold;
}
